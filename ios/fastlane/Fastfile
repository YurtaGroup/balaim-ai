default_platform(:ios)

# =====================================================================
# CHANGELOG GENERATION
#
# On every `fastlane beta`, we:
#   1. Read git log between the previous `testflight/<n>` tag and HEAD.
#   2. Pull out commit subjects + files that were deleted.
#   3. Send that text to TestFlight as the build's "What to Test".
#   4. Append the same text to repo-root CHANGELOG.md and commit it.
#   5. Tag the upload (`testflight/<build-number>`) and push tag + commit.
#
# So: you never have to write a changelog by hand, and nothing slips
# past — especially files you meant to delete.
# =====================================================================

MAX_CHANGELOG_CHARS = 3500  # TestFlight hard limit is 4000; keep margin.

def repo_root
  File.expand_path("../..", __dir__)
end

def run(cmd, cwd: repo_root)
  out = Dir.chdir(cwd) { `#{cmd}` }
  [out.strip, $?.success?]
end

def build_number
  # pubspec.yaml: "version: 1.2.0+10"  → "10"
  content = File.read(File.join(repo_root, "pubspec.yaml"))
  match = content.match(/^version:\s*[\d.]+\+(\d+)/)
  raise "Could not parse build number from pubspec.yaml" unless match
  match[1]
end

def generate_changelog(build_num)
  last_tag, ok = run("git describe --tags --match 'testflight/*' --abbrev=0 2>/dev/null")
  range = ok && !last_tag.empty? ? "#{last_tag}..HEAD" : "-10"

  subjects, _ = run("git log #{range} --no-merges --pretty=format:'%s'")
  commit_lines = subjects.split("\n").reject(&:empty?).map { |s| "• #{s}" }

  deleted_files = []
  if ok && !last_tag.empty?
    raw, _ = run("git log #{range} --diff-filter=D --name-only --pretty=format:")
    deleted_files = raw.split("\n").reject(&:empty?).uniq
  end

  header = "Balam.AI #{build_num}  •  #{Time.now.strftime('%Y-%m-%d')}"
  body = ["What's new:", *commit_lines].join("\n")
  if deleted_files.any?
    body += "\n\nRemoved files:\n" + deleted_files.take(25).map { |f| "• #{f}" }.join("\n")
    body += "\n… and #{deleted_files.size - 25} more" if deleted_files.size > 25
  end

  text = "#{header}\n\n#{body}"
  text = text[0, MAX_CHANGELOG_CHARS - 1] + "…" if text.length > MAX_CHANGELOG_CHARS
  text
end

def persist_changelog(build_num, text)
  path = File.join(repo_root, "CHANGELOG.md")
  existing = File.exist?(path) ? File.read(path) : "# Changelog\n\nEvery TestFlight build. Auto-generated by `fastlane beta`.\n\n"

  entry = "## #{text.lines.first.strip}\n\n" + text.lines.drop(2).join + "\n\n---\n\n"
  # Insert new entry right after the fixed header (before prior entries).
  head, tail = existing.split(/(?<=Auto-generated by `fastlane beta`\.\n\n)/m, 2)
  new_contents = "#{head}#{entry}#{tail || ''}"
  File.write(path, new_contents)

  run("git add CHANGELOG.md")
  run(%Q{git commit -m "Changelog for TestFlight build #{build_num}" --no-verify})

  tag = "testflight/#{build_num}"
  run("git tag -f #{tag} -m 'TestFlight build #{build_num}'")

  _, push_ok = run("git push origin HEAD")
  if push_ok
    run("git push origin #{tag} --force")
  else
    UI.important("Changelog committed locally but `git push` failed — push manually when network is back.")
  end
end

platform :ios do
  desc "Build and upload to TestFlight, with auto-generated changelog"
  lane :beta do
    Dir.chdir("../..") do
      sh("flutter build ipa --release")
    end

    key_id    = ENV["APP_STORE_CONNECT_KEY_ID"]    || "S33J7V6RL3"
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_file  = File.expand_path("~/private_keys/AuthKey_#{key_id}.p8")

    raise "APP_STORE_CONNECT_ISSUER_ID is not set. Export it from ~/.zshrc." if issuer_id.nil? || issuer_id.empty?
    raise "App Store Connect private key not found at #{key_file}." unless File.exist?(key_file)

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_file,
    )

    build_num = build_number
    changelog = generate_changelog(build_num)
    UI.message("Changelog for build #{build_num}:\n#{changelog}")

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/Balam.AI.ipa",
      changelog: changelog,
      skip_waiting_for_build_processing: true,
    )

    persist_changelog(build_num, changelog)
  end
end
