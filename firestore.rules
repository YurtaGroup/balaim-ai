rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can only read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Tracking — nested under user, private to that user
      match /tracking/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Feeding log — private to user
      match /feeding/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Diaper log — private to user
      match /diapers/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Consultations reference — private to user
      match /consultations/{consultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Lab results — private health data, user only
      match /labResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Insights — users can read their own, Cloud Functions write
    match /insights/{insightId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // Only Cloud Functions
    }

    // Proactive notices — "The App That Notices". User reads their own
    // inbox; Cloud Functions write. Users may update only dismissedAt /
    // actedAt (never the content) and cannot delete — history is
    // preserved for the analytics needed by the D30 kill-criteria.
    match /notices/{userId} {
      // The parent doc itself can exist as a placeholder; only owner reads.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      match /items/{noticeId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedAt', 'actedAt']);
        allow create, delete: if false; // Cloud Functions only
      }

      // Dedup sentinel docs — server-only (clients should never touch).
      match /_state/{stateId} {
        allow read, write: if false;
      }
    }

    // Balam Vault — family health documents. Owner creates items with
    // status 'pending'; the onVaultItemCreated Cloud Function processes
    // and updates status + extraction metadata server-side. Owner can
    // update the member tag / user-editable fields but NOT the
    // extraction payload. Delete allowed for owner (full vault control).
    match /vault/{userId}/items/{itemId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                     && request.resource.data.status == 'pending';
      allow update: if request.auth != null && request.auth.uid == userId
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['memberId', 'userNote', 'userTags']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Clinical audit log — Balam Box tier classifications. Server writes;
    // user can read their own records (for transparency); only licensed
    // clinicians (via server-side role check in Cloud Functions) may
    // update the mdReviewer* fields. Never deletable — this log is the
    // defense against any clinical-safety claim.
    match /clinical_audit/{caseId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false; // Cloud Functions only
    }

    // Emergency events — Balam Box Red-tier classifications. User can
    // read their own; only they can acknowledge (flip ackAt). Server
    // creates; never deleted.
    match /emergencies/{emergencyId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ackAt']);
      allow create, delete: if false; // Cloud Functions only
    }

    // Community posts — any authenticated user can read, author can write
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null; // For likes (in production, use Cloud Functions)
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

      // Comments
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }

    // Vendors — public read, admin write
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    // Products — public read, vendor write via Cloud Functions
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }
  }
}
